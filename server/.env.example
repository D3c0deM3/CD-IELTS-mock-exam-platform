# ========== DEVELOPMENT & PRODUCTION ==========
NODE_ENV=development
PORT=4000
JWT_SECRET=your_jwt_secret_here
ADMIN_FULL_NAME=Admin
ADMIN_PHONE_NUMBER=+998901234567
ADMIN_PASSWORD=change_me
ADMIN_SETUP_TOKEN=change_me_too
CORS_ORIGINS=https://cd-ielts.netlify.app,https://cd-ielts-mock-exam-platform.vercel.app

# ========== DATABASE CONFIGURATION ==========
# For local development:
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=yourpassword
# MYSQL_DATABASE=cd_mock

# For Heroku MySQL add-ons, set either add-on URL or explicit MYSQL_* vars:
# JAWSDB_URL=mysql://user:password@host:3306/database
# CLEARDB_DATABASE_URL=mysql://user:password@host:3306/database

# For Railway production, these are provided automatically:
# MYSQL_HOST=your-railway-host
# MYSQL_PORT=3306
# MYSQL_USER=railway-user
# MYSQL_PASSWORD=railway-password
# MYSQL_DATABASE=railway-db

# Railway will set these automatically, no need to add them to .env
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
